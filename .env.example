# ---------------------------------------------------------------------------
# Made In Americas — environment template
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# NEXT_PUBLIC_* are exposed to the browser — keep secrets OUT of them.
# ---------------------------------------------------------------------------

# --- Site / brand ---
NEXT_PUBLIC_SITE_URL="https://fabrera.com"
NEXT_PUBLIC_SITE_NAME="Fabrera"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""
DATABASE_URL=""

# --- AI ---
OPENAI_API_KEY=""
IMAGE_GEN_API_KEY=""

# --- Email (transactional + inbox relay for response tracking) ---
RESEND_API_KEY=""
INBOUND_EMAIL_WEBHOOK_SECRET=""

# --- Google Cloud / Vertex AI (service account; powers Gemini+Search grounding & GSC) ---
# GOOGLE_SERVICE_ACCOUNT_KEY holds the FULL service-account JSON (single-quoted).
GOOGLE_SERVICE_ACCOUNT_KEY=''
GOOGLE_CLOUD_PROJECT="bloom-platform-489223"
VERTEX_LOCATION="us-central1"
VERTEX_MODEL="gemini-2.5-flash"

# --- Google: Search Console, Analytics, Tag Manager ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SEARCH_CONSOLE_SITE_URL=""
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""
NEXT_PUBLIC_GTM_ID=""
GOOGLE_SITE_VERIFICATION=""
GOOGLE_MAPS_API_KEY=""

# --- Data sourcing / pipeline (optional/paid) ---
SERP_API_KEY=""
SCRAPER_API_KEY=""
ENRICHMENT_API_KEY=""

# --- Jobs / security ---
CRON_SECRET=""
